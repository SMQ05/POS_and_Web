generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
  engineType    = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String    @id @default(cuid())
  slug                String    @unique
  // Public B2B network handle (username) — editable, unique, defaults to slug.
  // Independent of slug (which still routes the web store).
  handle              String?   @unique
  // Business type for the in-platform B2B network: pharmacy | distributor | wholesaler.
  businessType        String    @default("pharmacy")
  name                String
  subscriptionPlan    String    @default("basic")
  isActive            Boolean   @default(true)
  status              String    @default("trial")
  trialEndsAt         DateTime?
  billingEmail        String?
  whatsappNumber      String?
  planPrice           Float?
  lastInvoiceAt       DateTime?
  settings            Json?
  fbrTokenEncrypted   String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users           User[]
  branches        Branch[]
  medicines       Medicine[]
  batches         Batch[]
  suppliers       Supplier[]
  customers       Customer[]
  sales           Sale[]
  saleReturns     SaleReturn[]
  purchases       Purchase[]
  expenses        Expense[]
  ledger          LedgerEntry[]
  webOrders       WebOrder[]
  auditLogs       AuditLog[]
  fbrSubmissions  FbrSubmission[]
  medicineSuppliers MedicineSupplier[]
  purchaseInvoices  PurchaseInvoice[]
  purchaseReturns   PurchaseReturn[]
  reconcileRuns     ReconcileRun[]
  reconcileEntries  ReconcileEntry[]
  notifications     Notification[]
  shiftSessions     ShiftSession[]
  dayCloses         DayClose[]
  promiseOrders     PromiseOrder[]
  partners          Partner[]
  outboxItems       OutboxEvent[]
  threads           Thread[]
  messages          Message[]
  pushSubscriptions PushSubscription[]
  connectionsA      Connection[]      @relation("connA")
  connectionsB      Connection[]      @relation("connB")
}

// ─── B2B Network (in-platform, no webhooks) ──────────────────────────────────
// Two on-platform tenants connect by handle, chat, and exchange orders. Every
// row links TWO tenants; access is membership-gated (OR aTenantId/bTenantId),
// never tenant-scoped. The pair is normalized (a=min,b=max) for a stable unique.
model Connection {
  id                  String   @id @default(cuid())
  aTenantId           String
  bTenantId           String
  aTenant             Tenant   @relation("connA", fields: [aTenantId], references: [id], onDelete: Cascade)
  bTenant             Tenant   @relation("connB", fields: [bTenantId], references: [id], onDelete: Cascade)
  status              String   @default("pending") // pending|accepted|declined|blocked|disconnected
  requestedByTenantId String
  blockedByTenantId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  messages ConnectionMessage[]
  orders   NetworkOrder[]

  @@unique([aTenantId, bTenantId])
  @@index([aTenantId, status])
  @@index([bTenantId, status])
}

model ConnectionMessage {
  id             String     @id @default(cuid())
  connectionId   String
  connection     Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  senderTenantId String
  senderUserId   String?
  senderName     String?
  body           String     @db.Text
  readAt         DateTime?
  createdAt      DateTime   @default(now())

  @@index([connectionId, createdAt])
}

model NetworkOrder {
  id               String     @id @default(cuid())
  connectionId     String
  connection       Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  buyerTenantId    String
  sellerTenantId   String
  orderNumber      String
  status           String     @default("placed") // placed|accepted|declined|shipped|received|cancelled
  notes            String?    @db.VarChar(1000)
  sourcePurchaseId String?
  buyerPurchaseId  String?
  totalQty         Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  items NetworkOrderItem[]

  @@unique([buyerTenantId, orderNumber])
  @@index([buyerTenantId, status])
  @@index([sellerTenantId, status])
}

model NetworkOrderItem {
  id              String       @id @default(cuid())
  orderId         String
  order           NetworkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName     String       @db.VarChar(300)
  strength        String?      @db.VarChar(100)
  packSize        String?      @db.VarChar(100)
  quantity        Int
  buyerMedicineId String?

  @@index([orderId])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name         String
  email        String
  passwordHash         String?
  role                 String
  permissions          Json
  isActive             Boolean   @default(true)
  emailConfirmed       Boolean   @default(false)
  passwordSetupToken   String?   @db.Text
  passwordSetupExpiry  DateTime?
  // POS sale authentication: short handle + 4-digit PIN. Used to identify the
  // salesperson at receipt time on a shared POS terminal. Hash is bcrypt.
  salesUsername        String?
  salesPinHash         String?
  // M6 — Per-branch RBAC. Array of { branchId, access: 'read' | 'full' }.
  // When null/empty, falls back to legacy single `branchId` (full access on
  // that branch only) for non-owners, or full access on all branches for
  // owners. The frontend uses this to hide write actions; the API enforces
  // it via requireBranchWrite middleware.
  branchAccess         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastLogin            DateTime?

  @@unique([tenantId, email])
  @@unique([tenantId, salesUsername])
  @@index([tenantId, role])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String
  city      String
  phone     String
  email     String
  isActive  Boolean  @default(true)
  /** 'main' = parent pharmacy pays the branch subscription;
   *  'self' = branch is invoiced separately (with optional discount). */
  billingPaidBy        String?  @default("main")
  /** Discount % off the standard sub-branch fee when self-billing. */
  subscriptionDiscount Float?   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  batches Batch[]

  @@index([tenantId])
}

model Medicine {
  id                     String   @id @default(cuid())
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                   String
  genericName            String
  brandName              String?
  category               String
  subCategory            String?
  description            String?
  dosageForm             String
  strength               String
  unit                   String
  units                  Json?
  barcode                String?
  qrCode                 String?
  /** Link back to the shared catalog row this medicine was created from. */
  masterProductId        String?
  /** DRAP registration number, when known (from the catalog / DRAP). */
  drapRegNo              String?
  isPrescriptionRequired Boolean  @default(false)
  classification         String
  substituteIds          Json?
  controlledSchedule     String?
  isActive               Boolean  @default(true)
  webLive                Boolean  @default(false)
  reorderLevel           Int      @default(0)
  reorderQuantity        Int      @default(0)
  hsCode                 String?
  fbrUom                 String?
  fbrSaleType            String?
  fbrScenarioId          String?
  drapRegistration       String?
  manufacturer           String?
  countryOfOrigin        String?
  packSize               String?
  storageInstructions    String?  @db.VarChar(300)
  taxRatePercent         Float?
  shelfLocation          String?
  rackNumber             String?
  mrp                    Float?
  purchaseRate           Float?
  // Trade price floor. Optional default at the medicine level — a batch can
  // override (different supplier → different TP). Resolves at POS as
  // batch.tradePrice ?? medicine.tradePrice ?? batch.salePrice.
  tradePrice             Float?
  maxStock               Int?
  allowLooseSale         Boolean   @default(true)
  schedule               String?
  composition            String?  @db.VarChar(500)
  // When false, this medicine is excluded from low-stock alerts and auto-PO
  // suggestions (e.g. discontinued lines kept on shelf for legacy customers).
  reorderActive          Boolean   @default(true)
  // Optional scanned/photographed barcode image (data URL). Useful when the
  // printed barcode on a manufacturer pack isn't human-typeable.
  barcodeImageUrl        String?  @db.MediumText
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  batches Batch[]

  @@unique([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, isActive, webLive])
}

model Batch {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicineId        String
  medicine          Medicine  @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  // The branch this physical stock lives in. Nullable for back-compat; existing
  // rows are backfilled to the main branch. Each branch holds its own batches.
  branchId          String?
  branch            Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batchNumber       String
  expiryDate        DateTime
  manufacturingDate DateTime?
  quantity          Int
  purchasePrice     Float
  salePrice         Float
  // Optional per-batch TP override (e.g. same drug, two distributors,
  // different trade prices).
  tradePrice        Float?
  mrp               Float
  supplierId        String?
  purchaseId        String?
  location          String?
  isActive          Boolean   @default(true)
  // Expiry-alert disposition lifecycle: active | pending_return | returned |
  // disposed. Lets the Alerts page show a batch as "pending return" and, once
  // actioned, record what happened to it + the value credited/written off.
  disposition       String    @default("active")
  // Why the batch was returned/written off: expiry | damage | waste. Null on
  // legacy rows = expiry (the only reason before damage/waste tracking).
  dispositionReason String?
  dispositionValue  Float?
  dispositionNote   String?   @db.Text
  dispositionAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, medicineId, batchNumber])
  @@index([tenantId, expiryDate])
  @@index([tenantId, branchId, medicineId])
}

// ─── Central shared product catalog (GLOBAL — not tenant-scoped) ─────────────
// One row per registered product, shared across all pharmacies. Holds only the
// non-sensitive master (brand, generic, strength, manufacturer, DRAP reg, pack
// GTINs). Pricing / stock / rack / loose-purchase NEVER live here — those stay
// in each tenant's Medicine/Batch. Grows from DRAP lookups + manual additions.
model MasterProduct {
  id                    String   @id @default(cuid())
  drapRegNo             String?  @unique
  brand                 String
  genericName           String?
  strength              String?
  unit                  String?
  dosageForm            String?
  manufacturer          String?
  atcCode               String?
  routeOfAdmin          String?
  packSizes             Json?
  composition           Json?
  /** Extra DRAP fields that don't have dedicated columns: brandName,
   *  registrationDate, companyAddress, labelClaim, productSpecification,
   *  manufacturingType, usedFor, containerClosure. */
  extra                 Json?
  /** 'drap' | 'contributed' | 'verified' — trust source. */
  source                String   @default("contributed")
  contributedByTenantId String?
  verified              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  gtins MasterProductGtin[]

  @@index([brand])
  @@index([genericName])
}

// Superadmin-only background job that walks DRAP brand prefixes and pre-loads
// the central MasterProduct catalog. Single global row (id 'singleton').
model DrapImportJob {
  id          String    @id @default("singleton")
  status      String    @default("idle") // idle | running | paused | done
  cursor      Int       @default(0)      // index into the prefix list
  prefixTotal Int       @default(0)
  queued      Int       @default(0)      // reg numbers discovered
  processed   Int       @default(0)      // products fetched + upserted
  failed      Int       @default(0)
  lastPrefix  String?
  lastError   String?   @db.Text
  startedAt   DateTime?
  updatedAt   DateTime  @updatedAt
}

// Each pack GTIN that resolves to a MasterProduct (a product has several pack
// sizes → several GTINs). Stored normalized to 14 digits for exact lookup.
model MasterProductGtin {
  id        String        @id @default(cuid())
  gtin      String        @unique
  productId String
  product   MasterProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Supplier {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  contactPerson  String
  phone          String
  email          String?
  address        String
  city           String
  ntn            String?
  gstNumber      String?
  creditLimit    Float    @default(0)
  currentBalance Float    @default(0)
  paymentTerms   Int      @default(0)
  isActive       Boolean  @default(true)
  // Optional weekly visit schedule, e.g. ["mon","wed","fri"]. Used by the
  // "Today's expected suppliers" dashboard widget when supplierVisitDaysEnabled
  // is on in AppSettings. Empty/null means "no schedule recorded".
  visitDays      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, name])
}

// M3 — Medicine ↔ Supplier (distributor) many-to-many mapping. Powers the
// "select supplier → see only their drugs" picker in PO creation, and lets the
// POS group batches by distributor. `isPrimary` flags the default supplier
// the auto-PO worker (M7) should pick when a medicine has multiple sources.
model MedicineSupplier {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicineId       String
  supplierId       String
  // Cached for quick PO-line auto-fill; not authoritative — batches carry the
  // real per-shipment price.
  lastTradePrice   Float?
  lastReceivedAt   DateTime?
  isPrimary        Boolean  @default(false)
  notes            String?  @db.VarChar(500)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, medicineId, supplierId])
  @@index([tenantId, supplierId])
  @@index([tenantId, medicineId])
}

// M3 — Multi-invoice partial GRN. One PO can now accept multiple supplier
// invoices (e.g. a partial delivery on day 1 with invoice #A, the remainder
// next week with invoice #B). The legacy Purchase.supplierInvoiceNumber stays
// in place for historical rows; new invoices land here.
model PurchaseInvoice {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseId            String
  supplierInvoiceNumber String
  // Optional scanned/photographed invoice image (data URL).
  imageUrl              String?   @db.MediumText
  totalAmount           Float
  receivedAt            DateTime  @default(now())
  notes                 String?   @db.VarChar(500)
  createdBy             String
  createdAt             DateTime  @default(now())

  @@index([tenantId, purchaseId])
}

// M7 — External partner (wholesale ERP, hospital, clinic). Carries the
// outbound URL + an encrypted API key. The real HTTP integration is stubbed
// in this milestone — the worker logs the attempt and marks the outbox row
// failed; once the wholesale app exists, swap in real fetch + signature.
model Partner {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type            String   // 'wholesale' | 'hospital' | 'clinic'
  name            String   @db.VarChar(200)
  baseUrl         String?  @db.VarChar(500)
  apiKeyEncrypted String?  @db.Text  // AES-GCM with FBR_TOKEN_KEY; reuses the FBR encrypt helper
  inboundSecret   String?  @db.VarChar(200)  // shared signature secret for inbound webhook
  isActive        Boolean  @default(true)
  notes           String?  @db.VarChar(500)
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  outboxItems     OutboxEvent[]
  threads         Thread[]

  @@index([tenantId, type])
}

// M7 — Outbound event queue. Real HTTP delivery is stubbed for now (worker
// marks rows failed with a placeholder); the schema and emitter wiring are in
// place so swapping in a real worker is a single function change.
model OutboxEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partnerId     String?
  partner       Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  event         String   // 'purchase_order.created' | 'purchase_return.created' | 'inbox_message.sent' | 'stock.low'
  payload       Json
  status        String   @default("pending") // 'pending' | 'sent' | 'failed' | 'skipped'
  retries       Int      @default(0)
  lastError     String?  @db.Text
  nextAttemptAt DateTime?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, event])
}

// M7 — Inbox thread. Either tenant-initiated or partner-initiated (inbound).
model Thread {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  subject     String   @db.VarChar(200)
  lastMessageAt DateTime @default(now())
  unreadCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]

  @@index([tenantId, lastMessageAt])
}

// M7 — Individual message inside a Thread.
model Message {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threadId     String
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType   String   // 'tenant' | 'wholesale' | 'hospital' | 'clinic' | 'system'
  senderName   String?
  body         String   @db.Text
  attachmentUrl String? @db.MediumText
  readAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([tenantId, threadId])
}

// M6 — Optional shift sessions for POS terminals. When AppSettings.shiftCloseEnabled
// is true, the POS requires an open shift before completing a sale. Each
// cashier opens with an opening-cash count and closes with a closing-cash
// count + auto-computed totals.
model ShiftSession {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String
  userId        String    // The cashier/salesperson who opened
  userName      String?
  openedAt      DateTime  @default(now())
  openingCash   Float     @default(0)
  closedAt      DateTime?
  closingCash   Float?
  // Cached totals at close — recomputed from sales when posting, but stored so
  // the Z-report stays consistent if later sales get edited.
  salesTotal    Float     @default(0)
  returnsTotal  Float     @default(0)
  // Per-operator cash reconciliation captured at close (Marg-style "Mode of
  // Payment" tally): { byMethod, cashCollected, expectedCash, difference,
  // salesCount, returnsCount }. Null on legacy/open shifts.
  summary       Json?
  status        String    @default("open") // 'open' | 'closed'
  notes         String?   @db.VarChar(500)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, branchId, status])
  @@index([tenantId, userId, status])
}

// M6 — Optional end-of-day close. Generates a Z-report-style summary for a
// branch on a given day. summary holds the breakdown by payment method,
// tax/discount totals, and FBR submission counts so historical day-closes
// stay readable even as live data evolves.
model DayClose {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String
  closedBy      String
  closedByName  String?
  closedAt      DateTime @default(now())
  // The business day this close applies to (different from closedAt — pharmacies
  // commonly close at midnight for the previous day's business).
  businessDate  DateTime
  openingCash   Float?
  closingCash   Float?
  salesTotal    Float    @default(0)
  returnsTotal  Float    @default(0)
  expensesTotal Float    @default(0)
  summary       Json     // { byMethod: {...}, taxTotal, discountTotal, fbrSubmitted, fbrFailed, salesCount }
  notes         String?  @db.VarChar(500)
  createdAt     DateTime @default(now())

  @@index([tenantId, branchId, businessDate])
}

// Customer promise / advance order (layaway). A customer asks for a medicine we
// don't stock; we take an advance, buy it later (recording our purchase cost),
// then settle on hand-over: collect the balance if the final price exceeds the
// advance, or refund if it's less.
model PromiseOrder {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String
  customerId     String?
  customerName   String
  customerPhone  String?
  itemName       String                       // free text — may not be in the catalog yet
  medicineId     String?                      // linked once it exists in our catalog
  quantity       Int       @default(1)
  advanceAmount  Float     @default(0)         // taken upfront
  purchaseCost   Float?                        // our cost, entered when we buy it
  finalPrice     Float?                        // price charged to the customer at hand-over
  status         String    @default("pending") // pending | purchased | settled | cancelled
  notes          String?   @db.VarChar(500)
  createdBy      String
  purchasedAt    DateTime?
  settledAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

// M5.1 — Web Push subscription. One per browser/device per user. Created via
// PushManager.subscribe() on the frontend after the user grants permission;
// the server reads the rows when emitting a notification to fan out OS-level
// pushes via web-push (RFC 8030 over VAPID).
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @db.VarChar(500)
  p256dh    String   @db.VarChar(200)
  authKey   String   @db.VarChar(100)
  userAgent String?  @db.VarChar(300)
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  @@unique([tenantId, endpoint])
  @@index([tenantId, userId])
}

// M5 — Persisted in-app notifications. Emitted by privileged actions (sale
// return, payment, reconcile post, etc.); the Header bell + Mobile More tab
// surface them. Scoping:
//   - scope='tenant': visible to everyone in the tenant
//   - scope='user'  : visible only to userId
//   - scope='role'  : visible to any user whose role matches `role`
// Inventory state alerts (expiry, low stock) remain computed-live to avoid
// emitting thousands of rows over time — only event-driven alerts persist.
model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope       String   // 'tenant' | 'user' | 'role'
  userId      String?
  role        String?
  title       String   @db.VarChar(200)
  body        String?  @db.VarChar(1000)
  severity    String   @default("info")  // 'info' | 'success' | 'warning' | 'critical'
  kind        String                     // 'sale_return' | 'payment' | 'reconcile' | 'purchase_return' | 'wholesale' | 'system'
  link        String?  @db.VarChar(300)  // optional in-app deep-link
  dismissedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, dismissedAt])
  @@index([tenantId, userId])
  @@index([tenantId, role])
}

// M4 — Physical stock count session. The user opens a run with a scope
// (whole inventory / one category / one shelf / one medicine / one supplier),
// enters counted quantities per batch, the diff against systemQty is computed,
// and on "post" the batches are adjusted + a ledger entry trail is written.
// status: 'open' (in progress) → 'posted' (adjustments applied) → optional
// 'cancelled'.
model ReconcileRun {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope        String   // 'all' | 'category' | 'shelf' | 'medicine' | 'supplier'
  scopeValue   String?  // category name / shelf id / medicineId / supplierId
  status       String   @default("open") // 'open' | 'posted' | 'cancelled'
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  notes        String?  @db.VarChar(500)
  createdBy    String
  postedBy     String?

  entries      ReconcileEntry[]

  @@index([tenantId, status])
  @@index([tenantId, startedAt])
}

// Per-batch counted vs system snapshot. `variance = countedQty - systemQty`
// (positive = found more than expected, negative = missing).
model ReconcileEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runId       String
  run         ReconcileRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  medicineId  String
  batchId     String?
  systemQty   Int
  countedQty  Int
  variance    Int
  notes       String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, runId])
  @@index([tenantId, medicineId])
}

// M3 — Returns to distributor. Mirrors SaleReturn but for the upstream
// direction. items is a JSON array of { medicineId, batchId, quantity, reason }.
// On status='posted', a future worker will decrement batch.quantity and write
// a LedgerEntry; for v1 that's done inline by the create handler.
model PurchaseReturn {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  returnNumber  String
  supplierId    String
  // Source PO is optional — sometimes you return a damaged batch that was
  // received outside the PO system (loose purchase).
  purchaseId    String?
  returnDate    DateTime @default(now())
  items         Json
  totalAmount   Float
  reason        String
  // Whether the batch quantity was decremented when the return was posted.
  // False = recorded but stock untouched (e.g. supplier rejected the return).
  stockAdjusted Boolean  @default(true)
  status        String   @default("posted")
  notes         String?  @db.VarChar(500)
  createdBy     String
  createdAt     DateTime @default(now())

  @@unique([tenantId, returnNumber])
  @@index([tenantId, supplierId])
  @@index([tenantId, returnDate])
}

model Customer {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  phone            String
  email            String?
  cnic             String?
  address          String?
  dateOfBirth      DateTime?
  allergies        Json?
  medicalHistory   String?
  isActive         Boolean   @default(true)
  totalPurchases   Float     @default(0)
  loyaltyPoints    Int       @default(0)
  registrationType String?
  buyerNtn         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId, name])
}

model Sale {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNumber      String
  branchId           String
  customerId            String?
  customerName       String?
  customerPhone      String?
  customerCnic       String?
  // Loyalty breakdown recorded at sale time (durable record for receipts/reports).
  loyaltyPointsEarned   Int     @default(0)
  loyaltyPointsRedeemed Int     @default(0)
  loyaltyDiscount       Float   @default(0)
  doctorName         String?
  prescriptionNumber String?
  // Scanned prescription stored as a data URL — can be hundreds of KB after
  // client-side compression, so Text/MediumText is required (default VARCHAR
  // is far too small).
  prescriptionImageUrl String? @db.MediumText
  saleDate           DateTime
  items              Json
  subtotal           Float
  discountAmount     Float
  taxAmount          Float
  totalAmount        Float
  paidAmount         Float
  balanceAmount      Float
  paymentMethods     Json
  status             String
  isPrescription     Boolean  @default(false)
  notes              String?
  fbrStatus          String?
  fbrInvoiceNumber   String?
  fbrBarcode         String?
  fbrQrPayload       String?  @db.Text
  fbrResponse        Json?
  createdBy          String
  // Salesperson who authenticated at receipt time via username+PIN. May differ
  // from createdBy when the POS terminal stays logged in under one account.
  // Name is snapshotted so receipts survive user deletion.
  salesPersonId      String?
  salesPersonName    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, saleDate])
}

model SaleReturn {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleId           String
  returnNumber     String
  returnDate       DateTime @default(now())
  items            Json
  totalAmount      Float
  refundMethod     Json
  reason           String
  restockInventory Boolean  @default(true)
  fbrStatus        String?
  fbrReference     String?
  fbrResponse      Json?
  createdBy        String
  createdAt        DateTime @default(now())

  @@unique([tenantId, returnNumber])
  @@index([tenantId, saleId])
  @@index([tenantId, returnDate])
}

model Purchase {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseNumber String
  supplierId     String
  branchId       String
  purchaseDate   DateTime
  dueDate        DateTime?
  // Payment terms in days. Calendar due date is computed at GRN time.
  paymentTermsDays Int?
  items          Json
  subtotal       Float
  discountAmount Float
  taxAmount      Float
  totalAmount    Float
  paidAmount     Float
  balanceAmount  Float
  // Supplier-issued invoice number + optional scanned image (data URL).
  supplierInvoiceNumber  String?
  supplierInvoiceImageUrl String? @db.MediumText
  // Recorded payments (cash/cheque/bank/etc.) — array of PurchasePayment.
  // Stored as JSON because cardinality is small (<10 per PO) and we never
  // query individual payment fields server-side.
  payments       Json?
  // Loose / local purchase (off-supplier urgent buy)
  isLoose        Boolean  @default(false)
  looseSource    String?
  status         String
  // True when the buyer closed a partially-received PO instead of chasing the
  // shortfall — status becomes 'received' but the UI still flags it as Partial.
  closedPartial  Boolean  @default(false)
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, purchaseNumber])
  @@index([tenantId, purchaseDate])
  @@index([tenantId, isLoose])
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    String
  description String
  amount      Float
  date        DateTime
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([tenantId, date])
}

model LedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          String
  referenceId   String
  referenceType String
  amount        Float
  description   String
  createdBy     String
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
}

model WebOrder {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber     String
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String
  customerCity    String
  items           Json
  subtotal        Float
  deliveryFee     Float
  total           Float
  paymentMethod   String
  paymentStatus   String
  orderStatus     String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  action         String
  module         String
  details        String
  entitySnapshot Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

model FbrSubmission {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type              String
  referenceId       String
  referenceType     String
  payload           Json
  status            String    @default("pending")
  retries           Int       @default(0)
  lastError         String?   @db.Text
  nextAttemptAt     DateTime?
  fbrInvoiceNumber  String?
  fbrBarcode        String?
  fbrQrPayload      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, referenceId])
}
