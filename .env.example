# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://pharmapos:pharmapos_password@127.0.0.1:3306/pharmapos_saas"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET="replace-this-with-a-long-random-production-secret"

# ─── FBR Token Encryption ─────────────────────────────────────────────────────
# Required when FBR integration is enabled.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FBR_TOKEN_KEY="64-character-hex-string-here"

# ─── Server binding ───────────────────────────────────────────────────────────
PORT=4000
# Set HOST=0.0.0.0 in production to accept connections from outside localhost
HOST=127.0.0.1
NODE_ENV=production
FRONTEND_ORIGIN="http://127.0.0.1:5173"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── WhatsApp (ycloud) ────────────────────────────────────────────────────────
# Get from https://app.ycloud.com
YCLOUD_API_KEY="your-ycloud-api-key-here"

# ─── App URL (used in email links) ───────────────────────────────────────────
APP_URL="https://pos.kynexsolutions.com"

# ─── Frontend (Vite build) ────────────────────────────────────────────────────
VITE_API_URL="http://127.0.0.1:4000"
VITE_TENANT_SLUG="your-pharmacy-slug"

# ─── Web Push (M5.1) ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:owner@example.com"
# Same as VAPID_PUBLIC_KEY but exposed to the Vite frontend bundle.
VITE_VAPID_PUBLIC_KEY=""

# RSA private key (PKCS8 PEM, newlines as \n) for decrypting KXV2 export files.
# Generate a keypair; embed the PUBLIC key in src/lib/secureFile.ts, keep this PRIVATE.
KXV_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
